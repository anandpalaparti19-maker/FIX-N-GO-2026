# ═══════════════════════════════════════════════════════
# Fix-N-Go Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/fixngo

# REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Set to 'true' to allow all origins in development (default: false)
CORS_ALLOW_ALL_DEV=true

# ── MQTT Broker ──────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USER=fixngo_app
MQTT_PASSWORD=fixngo_secure_2026

# ── Monitoring & Logging ─────────────────────────────
# SENTRY_DSN=

# ── Nodemailer (Gmail) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use Gmail App Password (not your regular password):
# https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password

# ── Twilio SMS ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified Twilio number in E.164 format
TWILIO_PHONE_NUMBER=+1234567890

# ── Stripe Payments ───────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Razorpay Payments ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=rzp_test_webhook_secret

# ── RazorpayX Payouts ─────────────────────────────────
# Set RAZORPAY_PAYOUTS_ENABLED=true + RazorpayX account number to enable
# automatic payouts. When false, withdrawals are queued for manual processing.
RAZORPAY_PAYOUTS_ENABLED=false
RAZORPAYX_ACCOUNT_NUMBER=

# ── Redis (optional, for OTP caching & sessions) ─────
# Comment out to disable Redis
REDIS_URL=redis://localhost:6379

# ── File Storage ──────────────────────────────────────
# Set to 'local' for dev, 'cloudinary' or 's3' for prod
UPLOAD_PROVIDER=local
# Cloudinary (if UPLOAD_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Seed Data ─────────────────────────────────────────
# Password used for seed accounts (default: FixNGo_Dev_2026!)
# SEED_PASSWORD=FixNGo_Dev_2026!
