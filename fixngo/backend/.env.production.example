# ==========================================
# Fix-N-Go Production Environment Template
# ==========================================
# IMPORTANT: Never commit the actual .env.production file to version control.
# Copy this file to .env.production and fill in the values.

# ── Core Server ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
# Comma-separated list of allowed origins for CORS (e.g., your admin panel domain)
CORS_ORIGIN=https://admin.fixngo.com,https://api.fixngo.com

# ── Database ──────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (use a dedicated DB user with strong password)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/fixngo_prod?retryWrites=true&w=majority

# ── Authentication & Security ─────────────────────────────────────────────
# Generate a secure 64-byte random string for JWT_SECRET
# e.g. using Node: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_generated_jwt_secret_here
JWT_EXPIRES_IN=7d

# Rate Limiting configuration
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ── Email Service (SMTP) ──────────────────────────────────────────────────
# Configure your production email provider (SendGrid, AWS SES, Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@fixngo.com
SMTP_PASS=your_app_specific_password
FROM_EMAIL="Fix-N-Go Support" <no-reply@fixngo.com>

# ── SMS Service (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_live_twilio_account_sid
TWILIO_AUTH_TOKEN=your_live_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Payment Gateway (Stripe / Razorpay) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Real-time & Location ──────────────────────────────────────────────────
# MQTT Broker URL (e.g. your production Mosquitto server)
MQTT_BROKER_URL=mqtt://your-mqtt-server.com:1883
MQTT_USER=fixngo_app
MQTT_PASSWORD=your_secure_mqtt_password

# ── Error Monitoring & Logging ────────────────────────────────────────────
# Sentry DSN for production error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/1234567

# ── Firebase Cloud Messaging (FCM) ────────────────────────────────────────
# Absolute path to the Firebase Admin service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/fix-n-go-firebase-adminsdk.json
