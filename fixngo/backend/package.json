{
  "name": "fix-n-go-backend",
  "version": "1.0.0",
  "description": "Backend for Fix-N-Go mobile repair platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'No build step required for this Express app'",
    "seed": "node src/scripts/seed.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@sentry/node": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "aedes": "^1.0.2",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cashfree-pg": "^6.0.4",
    "colors": "1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "mqtt": "^5.15.1",
    "multer": "^1.4.5-lts.1",
    "ngrok": "^5.0.0-beta.2",
    "nodemailer": "^6.10.1",
    "razorpay": "^2.9.6",
    "redis": "^4.6.12",
    "slugify": "^1.6.6",
    "twilio": "^4.23.0",
    "websocket-stream": "^5.5.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "setupFilesAfterFramework": [],
    "globalSetup": null,
    "setupFiles": []
  }
}
